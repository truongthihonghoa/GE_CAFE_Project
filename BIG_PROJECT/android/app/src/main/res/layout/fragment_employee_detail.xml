<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="32dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Thêm nhân viên"
                android:textColor="#000000"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Họ tên:"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="Họ tên"
                android:paddingHorizontal="20dp"
                android:textSize="16sp"
                android:textColor="#222"
                android:textColorHint="#9E9E9E"
                android:inputType="textPersonName" />

            <TextView
                android:id="@+id/tvNameError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*Họ tên không hợp lệ. Vui lòng nhập lại."
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Giới tính:"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerGender"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Ngày sinh:"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnDatePicker"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="20dp">

                <TextView
                    android:id="@+id/tvDob"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="06/02/2026"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#1A1A1A" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tvDobError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*Ngày sinh không hợp lệ. Vui lòng nhập lại."
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Căn cước công dân:"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCccd"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="CCCD (12 số)"
                android:paddingHorizontal="20dp"
                android:textSize="16sp"
                android:textColor="#222"
                android:textColorHint="#9E9E9E"
                android:inputType="number" />

            <TextView
                android:id="@+id/tvCccdError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*CCCD không hợp lệ. Vui lòng nhập lại."
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Số điện thoại:"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="SĐT (10 số)"
                android:paddingHorizontal="20dp"
                android:textSize="16sp"
                android:textColor="#222"
                android:textColorHint="#9E9E9E"
                android:inputType="phone" />

            <TextView
                android:id="@+id/tvPhoneError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*SĐT không hợp lệ. Vui lòng nhập lại."
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Địa chỉ:"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="Địa chỉ"
                android:paddingHorizontal="20dp"
                android:textSize="16sp"
                android:textColor="#222"
                android:textColorHint="#9E9E9E"
                android:inputType="textPostalAddress" />

            <TextView
                android:id="@+id/tvAddressError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*Địa chỉ không hợp lệ. Vui lòng nhập lại."
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Chức vụ:"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerPosition"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="20dp" />

            <TextView
                android:id="@+id/tvPositionError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*Chức vụ không hợp lệ. Vui lòng nhập lại."
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Số tài khoản ngân hàng:"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etBankAccount"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="Số tài khoản"
                android:paddingHorizontal="20dp"
                android:textSize="16sp"
                android:textColor="#222"
                android:textColorHint="#9E9E9E"
                android:inputType="number" />

            <TextView
                android:id="@+id/tvBankAccountError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*Số tài khoản không được để trống."
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Mã chi nhánh:"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etBranchId"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="Mã chi nhánh (ví dụ: CN01)"
                android:paddingHorizontal="20dp"
                android:textSize="16sp"
                android:textColor="#222"
                android:textColorHint="#9E9E9E"
                android:inputType="text" />

            <TextView
                android:id="@+id/tvBranchIdError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="*Mã chi nhánh không được để trống."
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#264625"
                android:text="Lưu"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFF"
                app:cornerRadius="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#D1D1D1"
                android:text="Hủy"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333"
                app:cornerRadius="32dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
