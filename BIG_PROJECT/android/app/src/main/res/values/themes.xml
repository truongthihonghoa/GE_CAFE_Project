<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.LTUD_N10" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#0A4D1E</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:statusBarColor">#F8F9FA</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.Rounded" parent="">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="CustomCalendar" parent="ThemeOverlay.Material3.Light">
        <item name="android:colorControlActivated">@color/calendar_selected</item>
        <item name="android:textColorPrimary">@color/calendar_text</item>
        <item name="android:textColorSecondary">@color/calendar_text_secondary</item>
        <item name="android:windowBackground">@android:color/white</item>
    </style>
</resources>