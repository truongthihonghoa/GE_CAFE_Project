<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Trạng thái đã chọn -->
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="6dp" />
                    <solid android:color="#0A4D1E" />
                </shape>
            </item>
            <item android:gravity="center" android:width="14dp" android:height="14dp">
                <vector android:width="24dp" android:height="24dp" android:viewportWidth="24" android:viewportHeight="24">
                    <path android:fillColor="#FFFFFF" android:pathData="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41-1.41z"/>
                </vector>
            </item>
        </layer-list>
    </item>
    
    <!-- Trạng thái chưa chọn -->
    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <stroke android:width="1.5dp" android:color="#CBD5E1" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</selector>
